EOF
npm run build && npx vercel --prod
cd ~/Downloads/betteryou && node -e "
const crypto = require('crypto');
async function gen() {
  const keys = await crypto.webcrypto.subtle.generateKey(
    { name: 'ECDH', namedCurve: 'P-256' }, true, ['deriveKey']
  );
  const pub = Buffer.from(await crypto.webcrypto.subtle.exportKey('raw', keys.publicKey)).toString('base64url');
  const priv = Buffer.from(await crypto.webcrypto.subtle.exportKey('pkcs8', keys.privateKey)).toString('base64url');
  console.log('PUBLIC=' + pub);
  console.log('PRIVATE=' + priv);
}
gen();
"import re

path = '/Users/callumbenson/Downloads/betteryou/src/App.js'

with open(path, 'r') as f:
    content = f.read()

# ── 1. REPLACE VAPID PLACEHOLDER ──────────────────────────────────────────
